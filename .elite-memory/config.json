{
  "version": "1.2.0",
  "workspace": "/home/admin/.openclaw/workspace",
  "layers": {
    "hot_ram": {
      "enabled": true,
      "file": "SESSION-STATE.md",
      "wal_protocol": true
    },
    "warm_store": {
      "enabled": true,
      "provider": "lancedb",
      "path": ".elite-memory/vectors",
      "auto_recall": true,
      "min_importance": 0.7
    },
    "cold_store": {
      "enabled": true,
      "provider": "git-notes",
      "path": ".elite-memory/git-notes"
    },
    "curated_archive": {
      "enabled": true,
      "memory_md": "MEMORY.md",
      "daily_logs": "memory/logs/",
      "projects": "memory/projects/"
    }
  },
  "extraction": {
    "auto_extract": true,
    "categories": ["preference", "decision", "fact", "procedure"],
    "min_confidence": 0.6
  },
  "retrieval": {
    "max_results": 10,
    "min_score": 0.3,
    "policy": "balanced"
  }
}
